# ─── Google Gemini ────────────────────────────────────────────────
# Pegue em https://aistudio.google.com/app/apikey (tier gratuito generoso)
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Modelo a usar (padrão: gemini-2.0-flash — rápido e grátis)
GEMINI_MODEL=gemini-2.0-flash

# ─── Evolution API ────────────────────────────────────────────────
# URL da sua instância Evolution API (sem barra no final)
EVOLUTION_URL=https://sua-evolution.up.railway.app
# API key global da Evolution (definida no .env do Evolution)
EVOLUTION_API_KEY=sua-api-key-global
# Nome da instância criada no Evolution (ex: esquina-burger)
EVOLUTION_INSTANCE=esquina-burger

# ─── Firebase Realtime Database ───────────────────────────────────
# Mesma URL usada pelo PDV (esquina-burger-sistema.html)
FIREBASE_DB_URL=https://esquina-burger-default-rtdb.firebaseio.com

# ─── Configurações do restaurante ─────────────────────────────────
RESTAURANTE_NOME=Esquina Burger
RESTAURANTE_UNIDADE=Vicentinópolis
TAXA_ENTREGA=5.00
HORARIO_FUNCIONAMENTO=Terça a Domingo, 18h às 23h
ENDERECO_LOJA=Rua Principal, 123 - Vicentinópolis

# ─── Segurança ────────────────────────────────────────────────────
# Token que o Evolution manda no header do webhook (defina igual no Evolution)
WEBHOOK_TOKEN=troque-por-um-token-secreto-aleatorio

# ─── Servidor ─────────────────────────────────────────────────────
PORT=3000
