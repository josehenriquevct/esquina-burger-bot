# ── Servidor ──
PORT=3000
NODE_ENV=production

# ── Segurança (OBRIGATÓRIOS em produção) ──
# Token para proteger endpoints da API do PDV (gere um aleatório forte)
BOT_TOKEN=gere_um_token_forte_aqui_ex_openssl_rand_hex_32
# Token que a Evolution API envia no webhook (configure na Evolution também)
WEBHOOK_TOKEN=gere_outro_token_forte_aqui

# ── CORS ──
# Domínios permitidos (separados por vírgula). Ex: https://meupdv.com,https://admin.esquinaburger.com
# Se vazio, só aceita localhost
CORS_ORIGINS=

# ── Rate Limiting ──
RATE_LIMIT_POR_MINUTO=20
MAX_TAMANHO_MSG=2000

# ── Restaurante ──
RESTAURANTE_NOME=Esquina Burger
RESTAURANTE_UNIDADE=Vicentinópolis
ENDERECO_LOJA=Rua Principal, 123 - Vicentinópolis
HORARIO_FUNCIONAMENTO=Terça a Domingo, 18h às 23h
TAXA_ENTREGA=5.00

# ── Google Gemini ──
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash

# ── Evolution API (WhatsApp) ──
EVOLUTION_URL=https://sua-instancia.evolution-api.com
EVOLUTION_API_KEY=sua_chave_evolution_aqui
EVOLUTION_INSTANCE=nome_da_instancia

# ── Firebase Realtime Database ──
FIREBASE_DB_URL=https://seu-projeto.firebaseio.com
# Database secret (encontre em Firebase Console > Project Settings > Service Accounts > Database Secrets)
# IMPORTANTE: Sem isso, qualquer pessoa com a URL do Firebase pode ler/escrever seus dados!
FIREBASE_AUTH_SECRET=seu_database_secret_aqui

# ── Imagem do cardápio ──
CARDAPIO_IMG_URL=https://raw.githubusercontent.com/josehenriquevct/esquina-burger-bot/main/cardapio.png

# ── URL pública (Railway preenche automaticamente) ──
BOT_URL=
